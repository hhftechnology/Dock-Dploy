"### tailscale-sidecar.service
[Unit]
Description=Docker Container tailscale-sidecar
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/docker start tailscale-sidecar
ExecStop=/usr/bin/docker stop tailscale-sidecar
Restart=on-failure

[Install]
WantedBy=multi-user.target
"
`;

