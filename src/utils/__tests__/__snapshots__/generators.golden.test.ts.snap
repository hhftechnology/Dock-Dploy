exports[`golden / generateKomodoToml > komodo TOML — vpn-tailscale-attached 1`] = `
"# Komodo configuration generated from Portainer stack
# Generated from Docker Compose configuration

[web]
image = "nginx:latest"
restart = "unless-stopped"

[tailscale]
image = "tailscale/tailscale:latest"
restart = "always"
volumes = [
  "tailscale:/var/lib/tailscale",
  "/dev/net/tun:/dev/net/tun",
]
environment = {}
environment.TS_STATE_DIR = "/var/lib/tailscale"
environment.TS_ACCEPT_DNS = "false"
environment.TS_AUTH_ONCE = "true"
environment.TS_USERSPACE = "false"
environment.TS_AUTHKEY = "$TS_AUTHKEY"
environment.TS_HOSTNAME = "edge"

"
`;

