exports[`golden / generateYaml > compose YAML — caps-security-and-lifecycle 1`] = `
"services:
  tailscale-sidecar:
    image: "tailscale/tailscale:stable"
    restart: unless-stopped
    privileged: false
    read_only: false
    security_opt: 
      - no-new-privileges:true
    cap_add: 
      - NET_ADMIN
      - NET_RAW
    cap_drop: 
      - ALL
    sysctls:
      net.ipv4.ip_forward: 1
    devices: 
      - /dev/net/tun:/dev/net/tun
    tmpfs: 
      - /tmp
    ulimits:
      nofile:
        soft: 65535
        hard: 65535
    init: true
    stop_grace_period: "10s"
    stop_signal: SIGTERM
    tty: true
    stdin_open: true
    hostname: ts-host"
`;

exports[`golden / generateYaml > compose YAML — env-dict-with-named-volume 1`] = `
"services:
  db:
    image: "postgres:16"
    restart: unless-stopped
    volumes: 
      - pg-data:/var/lib/postgresql/data
      - ./init.sql:/docker-entrypoint-initdb.d/init.sql:ro
    environment:
      POSTGRES_USER: app
      POSTGRES_PASSWORD: "\${POSTGRES_PASSWORD}"
      POSTGRES_DB: app
volumes:
  pg-data:
    driver: local"
`;

exports[`golden / generateYaml > compose YAML — healthcheck-and-deploy-resources 1`] = `
"services:
  api:
    image: "ghcr.io/example/api:1.0.0"
    restart: unless-stopped
    ports: 
      - 8080:8080/tcp
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/health", "||", "exit", "1"]
      interval: "30s"
      timeout: "5s"
      retries: 3
      start_period: "10s"
      start_interval: "5s"
    labels: 
      - traefik.enable=true
      - traefik.http.routers.api.rule=Host(\`api.example.com\`)
    deploy:
      resources:
        limits:
          cpus: "1.0"
          memory: "512M"
        reservations:
          cpus: "0.25"
          memory: "128M""
`;

exports[`golden / generateYaml > compose YAML — minimal-single-service 1`] = `
"services:
  web:
    image: "nginx:latest"
    restart: unless-stopped"
`;

exports[`golden / generateYaml > compose YAML — multi-service-with-deps-and-networks 1`] = `
"services:
  web:
    image: "nginx:1.27-alpine"
    restart: unless-stopped
    ports: 
      - 80:80/tcp
    depends_on: 
      - api
    networks: 
      - frontend
  api:
    image: "node:22-alpine"
    restart: unless-stopped
    environment: 
      - DATABASE_URL=\${DATABASE_URL}
    depends_on: 
      - db
    networks: 
      - frontend
      - backend
  db:
    image: "postgres:16"
    restart: unless-stopped
    volumes: 
      - pg-data:/var/lib/postgresql/data
    environment: 
      - POSTGRES_USER=app
      - POSTGRES_PASSWORD=\${POSTGRES_PASSWORD}
    networks: 
      - backend
networks:
  frontend:
    driver: bridge
    attachable: false
    internal: false
    enable_ipv6: false
  backend:
    driver: bridge
    attachable: false
    internal: true
    enable_ipv6: false
volumes:
  pg-data:
    driver: local"
`;

exports[`golden / generateYaml > compose YAML — ports-and-env-array 1`] = `
"services:
  api:
    image: "node:22-alpine"
    restart: always
    ports: 
      - 3000:3000/tcp
      - 9229:9229/tcp
    environment: 
      - NODE_ENV=production
      - PORT=3000
      - DATABASE_URL=\${DATABASE_URL}"
`;

exports[`golden / generateYaml > compose YAML — vpn-cloudflared-tunnel 1`] = `
"services:
  app:
    image: "ghcr.io/example/app:latest"
    restart: unless-stopped

# cloudflared VPN Sidecar Configuration
  cloudflared:
    restart: always
    image: cloudflare/cloudflared
    command: "--no-autoupdate tunnel run"
    environment:
      TUNNEL_TOKEN: "\${TUNNEL_TOKEN}""
`;

exports[`golden / generateYaml > compose YAML — vpn-netbird-mesh 1`] = `
"services:
  agent:
    image: "ghcr.io/example/agent:latest"
    restart: unless-stopped

# netbird VPN Sidecar Configuration
  netbird:
    restart: always
    image: "netbirdio/netbird:latest"
    privileged: true
    cap_add: 
      - NET_ADMIN
      - SYS_MODULE
    sysctls: 
      - net.ipv4.ip_forward=1
      - net.ipv6.conf.all.forwarding=1
    environment:
      NETBIRD_SETUP_KEY: "\${NETBIRD_SETUP_KEY}""
`;

exports[`golden / generateYaml > compose YAML — vpn-newt-tunnel 1`] = `
"services:
  app:
    image: "ghcr.io/example/app:latest"
    restart: unless-stopped
    networks: 
      - newt
  newt:
    restart: always
    image: fosrl/newt
    container_name: newt
    environment:
      PANGOLIN_ENDPOINT: "https://app.pangolin.net"
      NEWT_ID: "\${NEWT_ID}"
      NEWT_SECRET: "\${NEWT_SECRET}"
    networks: 
      - newt
networks:
  newt:
    external:
      name: newt"
`;

exports[`golden / generateYaml > compose YAML — vpn-tailscale-attached 1`] = `
"services:
  web:
    image: "nginx:latest"
    restart: unless-stopped
    network_mode: "service:tailscale"

# tailscale VPN Sidecar Configuration
# Routes traffic through Tailscale VPN
# Hostname: edge
  tailscale:
    restart: always
    image: "tailscale/tailscale:latest"
    privileged: true
    volumes: 
      - tailscale:/var/lib/tailscale
      - /dev/net/tun:/dev/net/tun
    environment:
      TS_STATE_DIR: /var/lib/tailscale
      TS_ACCEPT_DNS: false
      TS_AUTH_ONCE: true
      TS_USERSPACE: false
      TS_AUTHKEY: $TS_AUTHKEY
      TS_HOSTNAME: edge
volumes:
  tailscale:"
`;

exports[`golden / generateYaml > compose YAML — vpn-wireguard-attached 1`] = `
"services:
  torrent:
    image: "linuxserver/qbittorrent:latest"
    restart: unless-stopped

# wireguard VPN Sidecar Configuration
  wireguard:
    restart: always
    image: "linuxserver/wireguard:latest"
    cap_add: 
      - NET_ADMIN
      - SYS_MODULE
    environment:
      PUID: 1000
      PGID: 1000
      TZ: Etc/UTC
    sysctls: 
      - net.ipv4.conf.all.src_valid_mark=1
    volumes: 
      - /etc/wireguard/wg0.conf:/config"
`;

exports[`golden / generateYaml > compose YAML — vpn-zerotier-network 1`] = `
"services:
  node:
    image: "ghcr.io/example/node:latest"
    restart: unless-stopped

# zerotier VPN Sidecar Configuration
  zerotier:
    restart: always
    image: "zerotier/zerotier:latest"
    privileged: true
    networks: 
      - host
    volumes: 
      - /var/lib/zerotier-one:/var/lib/zerotier-one
    environment:
      ZT_NC_NETWORK: "\${ZT_NETWORK_ID}""
`;
